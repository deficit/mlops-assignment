{
  "title": "vLLM serving",
  "uid": "vllm-serving",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "tags": ["vllm", "observability"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active Requests (Running vs Waiting)",
      "description": "Active running requests executing on GPU vs queued waiting requests.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm:num_requests_running",
          "legendFormat": "Running"
        },
        {
          "refId": "B",
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "Waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "E2E Request Latency Percentiles",
      "description": "End-to-end request latency percentiles (P50, P90, P95, P99).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Time to First Token (TTFT) Percentiles",
      "description": "Time to first token (TTFT) latency distribution.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50 TTFT"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95 TTFT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Inter-Token Latency (TPOT) Percentiles",
      "description": "Time per output token (TPOT) distribution.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50 TPOT"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95 TPOT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token Throughput Rate",
      "description": "Rate of prompt (input) and generation (output) tokens processed.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(vllm:prompt_tokens_total[1m])",
          "legendFormat": "Prompt Tokens/s"
        },
        {
          "refId": "B",
          "expr": "rate(vllm:generation_tokens_total[1m])",
          "legendFormat": "Generation Tokens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "KV Cache Usage Percentage",
      "description": "Percentage of KV cache usage on GPU.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm:gpu_cache_usage_perc * 100",
          "legendFormat": "KV Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Success / Finish Reason Rate",
      "description": "Finished request throughput split by reason (stop, length, abort, etc.).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(vllm:request_success_total[1m])) by (finished_reason)",
          "legendFormat": "{{finished_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Preemption Rate",
      "description": "Rate of request preemptions occurring due to KV cache pressure.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(vllm:num_preemptions_total[1m])",
          "legendFormat": "Preemptions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    }
  ]
}
